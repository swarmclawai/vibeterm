{
  "name": "@swarmclawai/vibeterm",
  "version": "0.2.0",
  "type": "module",
  "description": "Desktop-first terminal workspace with Tauri, launcher-aware sessions, and a companion browser.",
  "homepage": "https://github.com/swarmclawai/vibeterm#readme",
  "bugs": {
    "url": "https://github.com/swarmclawai/vibeterm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/vibeterm.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "vibeterm": "./bin/vibeterm.mjs"
  },
  "files": [
    "bin",
    "public",
    "scripts",
    "src",
    "src-tauri",
    "index.html",
    "tsconfig.json",
    "tsconfig.node.json",
    "vite.config.ts"
  ],
  "scripts": {
    "start": "node scripts/run-mode.mjs",
    "desktop": "node scripts/run-mode.mjs desktop",
    "desktop:dev": "npm run tauri -- dev",
    "web": "node scripts/run-mode.mjs web",
    "web:password": "node scripts/run-mode.mjs web --password",
    "dev": "vite --host 0.0.0.0",
    "dev:lan": "vite --host 0.0.0.0 --port 1420",
    "dev:remote": "node scripts/dev-remote.mjs",
    "web:dev": "node scripts/dev-remote.mjs",
    "web:dev:password": "node scripts/dev-remote.mjs --password",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "remote:server": "cargo run --manifest-path src-tauri/Cargo.toml --bin remote_server",
    "remote:server:release": "cargo run --release --manifest-path src-tauri/Cargo.toml --bin remote_server"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
